# ══════════════════════════════════════════════════════════════
# US500 AI Signal System — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ─── cTrader Open API ────────────────────────────────────────
# Get from: https://openapi.ctrader.com/
# 1. Register an application
# 2. Get client ID and secret from the dashboard
# 3. Generate access token via OAuth flow
CTRADER_CLIENT_ID=your_client_id
CTRADER_CLIENT_SECRET=your_client_secret
CTRADER_ACCESS_TOKEN=your_access_token
CTRADER_ACCOUNT_ID=your_account_id
CTRADER_HOST=live.ctraderapi.com
CTRADER_PORT=5035

# Token expiry tracking (set to date you generated the token)
# Format: ISO 8601 with timezone
CTRADER_TOKEN_CREATED=2025-03-01T00:00:00+00:00

# ─── Telegram Bots ───────────────────────────────────────────
# Create TWO separate bots via @BotFather on Telegram
# Bot 1: Trade signals (goes to your trading channel)
# Bot 2: System health (goes to your admin channel)
# Get chat IDs by sending a message to the bot then visiting:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_TRADE_TOKEN=your_trade_bot_token
TELEGRAM_TRADE_CHAT_ID=your_trade_chat_id
TELEGRAM_SYSTEM_TOKEN=your_system_bot_token
TELEGRAM_SYSTEM_CHAT_ID=your_system_chat_id

# ─── Groq AI (optional — sentiment analysis) ────────────────
# Get from: https://console.groq.com/keys
# If empty: sentiment defaults to NEUTRAL (system still works)
GROQ_API_KEY=your_groq_api_key

# ─── News Calendar ──────────────────────────────────────────
# Uses free faireconomy.media feed — no API key needed
# Calendar fetched automatically at startup each day
